# Copy to .env and fill in. .env is git-ignored.

# Argo API endpoint (must include /v1 if the OpenAI-compatible spec requires it)
ARGO_BASE_URL=https://apps.inside.anl.gov:8080/argoapi/v1

# Argo username or token (per Argo internal docs)
ARGO_API_KEY=your-argo-token-or-username

# Model hosted on Argo
ARGO_MODEL=claudeopus47

# Optional: explicit Host header override sent with each request
ARGO_HOST_HEADER=apps.inside.anl.gov

# Optional: HTTP timeout (seconds) and retry count for Argo calls
ARGO_TIMEOUT_SECONDS=60
ARGO_MAX_RETRIES=2

# Optional: tomocupy Docker image and CLI binary used by the imaging agent
TOMOCUPY_IMAGE=tomocupy:1.1.0-cu124
TOMOCUPY_DOCKER_BIN=docker
